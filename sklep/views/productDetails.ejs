<%- include('partials/header') %>

<h2><%= product.title %></h2>
<p><%= product.description %></p>
<p>Cena: <%= product.price %> zł</p>

<h3>Opinie</h3>
<% reviews.forEach(review => { %>
    <div>
        <strong>Ocena: <%= review.value || '-' %> / 5</strong><br>
        <%= review.content %>
    </div>
<% }) %>

<% if (role === 'client') { %>
    <h3>Dodaj opinię i ocenę</h3>
    <form method="POST" action="/client/review/<%= product._id %>">
        <label>Ocena (1-5):</label>
        <input type="number" name="value" min="1" max="5" value="5" required><br><br>

        <label>Treść opinii:</label><br>
        <textarea name="content" rows="4" cols="50" required></textarea><br><br>

        <button>Dodaj opinię</button>
    </form>
<% } %>

<%- include('partials/footer') %>
