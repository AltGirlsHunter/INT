<%- include('../partials/header') %>

<div class="auth-wrapper">
  <div class="auth-card">
    <div class="auth-header">
      <h1 class="auth-title">Rejestracja</h1>
      <p class="auth-sub">Dołącz do społeczności graczy</p>
    </div>

    <%- include('../partials/flash') %>

    <form action="/auth/register" method="POST" class="auth-form">
      <div class="form-group">
        <label for="username" class="form-label">Nazwa gracza</label>
        <input type="text" id="username" name="username" class="form-input" placeholder="MegaGracz123" required minlength="3" maxlength="50">
      </div>
      <div class="form-group">
        <label for="email" class="form-label">Email</label>
        <input type="email" id="email" name="email" class="form-input" placeholder="gracz@example.com" required>
      </div>
      <div class="form-group">
        <label for="password" class="form-label">Hasło</label>
        <input type="password" id="password" name="password" class="form-input" placeholder="Min. 6 znaków" required minlength="6">
      </div>
      <div class="form-group">
        <label for="password_confirm" class="form-label">Potwierdź hasło</label>
        <input type="password" id="password_confirm" name="password_confirm" class="form-input" placeholder="Powtórz hasło" required>
      </div>
      <div class="form-note">
        🎁 Nowe konto startuje z <strong>1000 G</strong> na pierwsze zakupy!
      </div>
      <button type="submit" class="btn btn-primary btn-full btn-lg">Utwórz konto</button>
    </form>

    <p class="auth-footer">Masz już konto? <a href="/auth/login">Zaloguj się</a></p>
  </div>
</div>

<%- include('../partials/footer') %>
