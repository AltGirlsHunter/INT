<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <title>Rejestracja – Virtual Pet</title>
</head>
<body>
  <h1>Rejestracja</h1>
  <% if (error) { %>
    <p style="color:red;"><%= error %></p>
  <% } %>
  <form method="POST" action="/auth/register">
    <label>Nazwa użytkownika:<br>
      <input type="text" name="username" required>
    </label><br><br>
    <label>Hasło:<br>
      <input type="password" name="password" required>
    </label><br><br>
    <button type="submit">Zarejestruj się</button>
  </form>
  <p>Masz już konto? <a href="/auth/login">Zaloguj się</a></p>
</body>
</html>
